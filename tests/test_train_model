# 1. INSTANCES DE MODÈLES  ─  get_models()
# ══════════════════════════════════════════════════════════════════════════════

class TestGetModels:
    """
    Vérifie que get_models() :
      - retourne bien un dictionnaire
      - contient exactement les 3 modèles attendus
      - chaque modèle est une instance sklearn-compatible
      - les noms correspondent aux clés attendues
    """

    def test_retourne_un_dictionnaire(self):
        """
        get_models() doit retourner un dict, pas une liste ni autre chose.
        """
        result = get_models()
        assert isinstance(result, dict), (
            f"get_models() retourne un {type(result).__name__}, attendu dict"
        )

    def test_trois_modeles_presents(self):
        """
        Le dictionnaire doit contenir exactement 3 modèles.
        """
        models = get_models()
        assert len(models) == 3, (
            f"Attendu 3 modèles, obtenu {len(models)} : {list(models.keys())}"
        )

    def test_cles_attendues_presentes(self):
        """
        Les clés doivent être exactement : 'Random Forest', 'XGBoost', 'LightGBM'.
        """
        models = get_models()
        cles_attendues = {"Random Forest", "XGBoost", "LightGBM"}
        cles_obtenues  = set(models.keys())
        assert cles_obtenues == cles_attendues, (
            f"Clés obtenues : {cles_obtenues}\n"
            f"Clés attendues : {cles_attendues}"
        )

    def test_chaque_modele_a_predict(self):
        """
        Chaque modèle doit exposer une méthode predict() (interface sklearn).
        """
        for nom, modele in get_models().items():
            assert hasattr(modele, "predict"), (
                f"Le modèle '{nom}' n'a pas de méthode predict()"
            )

    def test_chaque_modele_a_predict_proba(self):
        """
        Chaque modèle doit exposer predict_proba() pour le calcul du ROC-AUC.
        """
        for nom, modele in get_models().items():
            assert hasattr(modele, "predict_proba"), (
                f"Le modèle '{nom}' n'a pas de méthode predict_proba()"
            )

    def test_chaque_modele_a_fit(self):
        """
        Chaque modèle doit exposer fit() pour l'entraînement.
        """
        for nom, modele in get_models().items():
            assert hasattr(modele, "fit"), (
                f"Le modèle '{nom}' n'a pas de méthode fit()"
            )

    def test_modeles_non_entrained_par_defaut(self):
        """
        Les modèles retournés ne doivent pas encore être entraînés.
        Un modèle non entraîné lève NotFittedError si on appelle predict().
        """
        from sklearn.exceptions import NotFittedError
        X_dummy = np.array([[1, 2, 3]])

        for nom, modele in get_models().items():
            with pytest.raises(Exception):  # NotFittedError ou AttributeError
                modele.predict(X_dummy)

    def test_random_state_fixe_pour_reproductibilite(self):
        """
        Deux appels successifs à get_models() doivent retourner des modèles
        avec le même random_state (reproductibilité des résultats).
        """
        m1 = get_models()
        m2 = get_models()

        for nom in m1:
            rs1 = getattr(m1[nom], "random_state", None)
            rs2 = getattr(m2[nom], "random_state", None)
            assert rs1 == rs2, (
                f"Modèle '{nom}' : random_state différent entre deux appels "
                f"({rs1} vs {rs2})"
            )



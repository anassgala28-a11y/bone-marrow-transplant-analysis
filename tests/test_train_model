class TestEvaluateModel:
    """
    Vérifie que evaluate_model() :
      - retourne un dictionnaire avec les 5 métriques attendues
      - toutes les métriques sont dans [0, 1]
      - les valeurs sont arrondies (pas de flottants bruts à 15 décimales)
      - ROC-AUC > 0.5 sur un modèle entraîné (meilleur que le hasard)
    """

    METRIQUES_ATTENDUES = {"Accuracy", "Precision", "Recall", "F1-Score", "ROC-AUC"}

    def test_retourne_un_dictionnaire(self, modele_entraine, jeu_classification):
        """
        evaluate_model() doit retourner un dict.
        """
        result = evaluate_model(
            modele_entraine,
            jeu_classification["X_test"],
            jeu_classification["y_test"]
        )
        assert isinstance(result, dict), (
            f"Type retourné : {type(result).__name__}, attendu dict"
        )

    def test_toutes_les_metriques_presentes(self, modele_entraine, jeu_classification):
        """
        Le dict doit contenir exactement les 5 clés de métriques attendues.
        """
        result = evaluate_model(
            modele_entraine,
            jeu_classification["X_test"],
            jeu_classification["y_test"]
        )
        cles_manquantes = self.METRIQUES_ATTENDUES - set(result.keys())
        assert cles_manquantes == set(), (
            f"Métriques manquantes dans le résultat : {cles_manquantes}"
        )

    def test_metriques_dans_intervalle_0_1(self, modele_entraine, jeu_classification):
        """
        Toutes les métriques de classification sont dans [0.0, 1.0].
        """
        result = evaluate_model(
            modele_entraine,
            jeu_classification["X_test"],
            jeu_classification["y_test"]
        )
        for metrique, valeur in result.items():
            assert 0.0 <= valeur <= 1.0, (
                f"Métrique '{metrique}' hors de [0, 1] : {valeur}"
            )

    def test_roc_auc_superieur_au_hasard(self, modele_entraine, jeu_classification):
        """
        Un modèle entraîné doit avoir ROC-AUC > 0.5 (mieux qu'aléatoire).
        """
        result = evaluate_model(
            modele_entraine,
            jeu_classification["X_test"],
            jeu_classification["y_test"]
        )
        assert result["ROC-AUC"] > 0.5, (
            f"ROC-AUC = {result['ROC-AUC']:.4f} — le modèle performe comme le hasard."
        )

    def test_valeurs_arrondies_4_decimales(self, modele_entraine, jeu_classification):
        """
        Les valeurs doivent être arrondies à 4 décimales maximum
        (évite les floats bruts peu lisibles).
        """
        result = evaluate_model(
            modele_entraine,
            jeu_classification["X_test"],
            jeu_classification["y_test"]
        )
        for metrique, valeur in result.items():
            arrondi = round(valeur, 4)
            assert valeur == arrondi, (
                f"Métrique '{metrique}' : valeur {valeur} non arrondie à 4 déc. "
                f"(attendu {arrondi})"
            )

    def test_metriques_consistantes(self, modele_entraine, jeu_classification):
        """
        Deux appels successifs à evaluate_model() avec les mêmes données
        doivent retourner des résultats identiques (déterminisme).
        """
        r1 = evaluate_model(
            modele_entraine,
            jeu_classification["X_test"],
            jeu_classification["y_test"]
        )
        r2 = evaluate_model(
            modele_entraine,
            jeu_classification["X_test"],
            jeu_classification["y_test"]
        )
        assert r1 == r2, (
            "evaluate_model() retourne des résultats différents sur la même entrée."
        )



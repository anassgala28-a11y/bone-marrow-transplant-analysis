# 3. ENTRAÎNEMENT DE TOUS LES MODÈLES  ─  train_all_models()
# ══════════════════════════════════════════════════════════════════════════════

class TestTrainAllModels:
    """
    Vérifie que train_all_models() :
      - retourne 4 éléments (best_model, best_name, results, all_models)
      - le meilleur modèle est sélectionné par ROC-AUC max
      - 'results' contient une entrée par modèle avec toutes les métriques
      - 'all_models' contient des estimateurs entraînés (ont predict())
      - XGBoost est sélectionné quand il a le ROC-AUC le plus élevé
    """

    def test_retourne_quatre_elements(self, jeu_classification):
        """
        train_all_models() doit retourner exactement 4 éléments.
        """
        result = train_all_models(
            jeu_classification["X_train"], jeu_classification["X_test"],
            jeu_classification["y_train"], jeu_classification["y_test"]
        )
        assert len(result) == 4, (
            f"Attendu 4 éléments, obtenu {len(result)}"
        )

    def test_best_name_est_une_chaine(self, jeu_classification):
        """
        Le nom du meilleur modèle doit être une chaîne non vide.
        """
        _, best_name, _, _ = train_all_models(
            jeu_classification["X_train"], jeu_classification["X_test"],
            jeu_classification["y_train"], jeu_classification["y_test"]
        )
        assert isinstance(best_name, str) and len(best_name) > 0, (
            f"best_name invalide : {best_name!r}"
        )

    def test_best_name_parmi_les_modeles_connus(self, jeu_classification):
        """
        Le nom du meilleur modèle doit être l'un des 3 modèles de get_models().
        """
        _, best_name, _, _ = train_all_models(
            jeu_classification["X_train"], jeu_classification["X_test"],
            jeu_classification["y_train"], jeu_classification["y_test"]
        )
        noms_valides = {"Random Forest", "XGBoost", "LightGBM"}
        assert best_name in noms_valides, (
            f"best_name = '{best_name}' — pas dans {noms_valides}"
        )

    def test_best_model_a_roc_auc_max(self, jeu_classification):
        """
        Le modèle sélectionné doit effectivement avoir le ROC-AUC le plus élevé
        parmi tous les modèles évalués.
        """
        best_model, best_name, results, _ = train_all_models(
            jeu_classification["X_train"], jeu_classification["X_test"],
            jeu_classification["y_train"], jeu_classification["y_test"]
        )
        roc_aucs = {nom: metrics["ROC-AUC"] for nom, metrics in results.items()}
        meilleur_roc = max(roc_aucs, key=roc_aucs.get)
        assert best_name == meilleur_roc, (
            f"Modèle sélectionné : '{best_name}' (ROC-AUC={roc_aucs[best_name]:.4f})\n"
            f"Modèle avec ROC-AUC max : '{meilleur_roc}' (ROC-AUC={roc_aucs[meilleur_roc]:.4f})"
        )

    def test_results_contient_tous_les_modeles(self, jeu_classification):
        """
        'results' doit contenir une entrée pour chaque modèle de get_models().
        """
        _, _, results, _ = train_all_models(
            jeu_classification["X_train"], jeu_classification["X_test"],
            jeu_classification["y_train"], jeu_classification["y_test"]
        )
        noms_attendus = set(get_models().keys())
        noms_obtenus  = set(results.keys())
        assert noms_obtenus == noms_attendus, (
            f"Modèles manquants dans results : {noms_attendus - noms_obtenus}"
        )

    def test_results_metriques_valides(self, jeu_classification):
        """
        Chaque entrée de 'results' doit contenir les 5 métriques
        avec des valeurs dans [0, 1].
        """
        _, _, results, _ = train_all_models(
            jeu_classification["X_train"], jeu_classification["X_test"],
            jeu_classification["y_train"], jeu_classification["y_test"]
        )
        metriques = {"Accuracy","Precision","Recall","F1-Score","ROC-AUC"}
        for nom, metrics in results.items():
            for m in metriques:
                assert m in metrics, f"Métrique '{m}' manquante pour le modèle '{nom}'"
                assert 0.0 <= metrics[m] <= 1.0, (
                    f"Modèle '{nom}', '{m}' = {metrics[m]} hors de [0, 1]"
                )

    def test_all_models_sont_entraines(self, jeu_classification):
        """
        Tous les modèles dans 'all_models' doivent pouvoir faire des
        prédictions (preuve qu'ils ont bien été entraînés avec fit()).
        """
        _, _, _, all_models = train_all_models(
            jeu_classification["X_train"], jeu_classification["X_test"],
            jeu_classification["y_train"], jeu_classification["y_test"]
        )
        for nom, modele in all_models.items():
            try:
                preds = modele.predict(jeu_classification["X_test"][:5])
                assert len(preds) == 5
            except Exception as e:
                pytest.fail(
                    f"Le modèle '{nom}' n'est pas entraîné ou predict() échoue : {e}"
                )

    def test_selection_par_roc_auc_mock(self):
        """
        Vérifie la logique de sélection avec des métriques mockées :
        quand XGBoost a le ROC-AUC le plus élevé, il doit être sélectionné.
        Utilise un mock pour éviter l'entraînement réel.
        """
        metriques_mockees = {
            "Random Forest": {"Accuracy":0.79,"Precision":0.80,"Recall":0.78,"F1-Score":0.79,"ROC-AUC":0.84},
            "LightGBM":      {"Accuracy":0.82,"Precision":0.83,"Recall":0.81,"F1-Score":0.82,"ROC-AUC":0.86},
            "XGBoost":       {"Accuracy":0.83,"Precision":0.85,"Recall":0.81,"F1-Score":0.83,"ROC-AUC":0.87},
        }
        df_results = pd.DataFrame(metriques_mockees).T
        meilleur = df_results["ROC-AUC"].idxmax()
        assert meilleur == "XGBoost", (
            f"Sélection par ROC-AUC max attendue : 'XGBoost', obtenu : '{meilleur}'"
        )



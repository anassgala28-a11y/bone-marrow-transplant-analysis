# 4. SAUVEGARDE DU MODÈLE  ─  save_model()
# ══════════════════════════════════════════════════════════════════════════════

class TestSaveModel:
    """
    Vérifie que save_model() :
      - crée le fichier .pkl au bon chemin
      - le nom du fichier correspond au nom du modèle (slug)
      - le répertoire de sortie est créé s'il n'existe pas
      - retourne le chemin du fichier sauvegardé
      - le fichier peut être rechargé avec joblib.load()
    """

    def test_fichier_pkl_cree(self, modele_entraine):
        """
        Après save_model(), le fichier .pkl doit exister sur le disque.
        """
        with tempfile.TemporaryDirectory() as tmpdir:
            chemin = save_model(modele_entraine, "XGBoost", output_dir=tmpdir)
            assert os.path.exists(chemin), (
                f"Le fichier .pkl n'a pas été créé : {chemin}"
            )

    def test_nom_fichier_correspond_au_modele(self, modele_entraine):
        """
        Le nom du fichier doit être dérivé du nom du modèle
        (minuscules, espaces → underscores, extension .pkl).
        """
        with tempfile.TemporaryDirectory() as tmpdir:
            chemin = save_model(modele_entraine, "Random Forest", output_dir=tmpdir)
            nom_fichier = os.path.basename(chemin)
            assert nom_fichier == "random_forest.pkl", (
                f"Nom de fichier attendu : 'random_forest.pkl', obtenu : '{nom_fichier}'"
            )

    def test_xgboost_slug_correct(self, modele_entraine):
        """
        Pour 'XGBoost', le fichier doit s'appeler 'xgboost.pkl'.
        """
        with tempfile.TemporaryDirectory() as tmpdir:
            chemin = save_model(modele_entraine, "XGBoost", output_dir=tmpdir)
            nom_fichier = os.path.basename(chemin)
            assert nom_fichier == "xgboost.pkl", (
                f"Attendu 'xgboost.pkl', obtenu '{nom_fichier}'"
            )

    def test_dossier_cree_si_absent(self, modele_entraine):
        """
        Si le dossier de sortie n'existe pas encore, save_model() doit le créer.
        """
        with tempfile.TemporaryDirectory() as tmpdir:
            nouveau_dossier = os.path.join(tmpdir, "sous_dossier", "models")
            assert not os.path.exists(nouveau_dossier)

            save_model(modele_entraine, "XGBoost", output_dir=nouveau_dossier)
            assert os.path.exists(nouveau_dossier), (
                f"Le dossier '{nouveau_dossier}' n'a pas été créé par save_model()"
            )

    def test_retourne_le_chemin_du_fichier(self, modele_entraine):
        """
        save_model() doit retourner le chemin complet du fichier .pkl créé.
        """
        with tempfile.TemporaryDirectory() as tmpdir:
            chemin = save_model(modele_entraine, "XGBoost", output_dir=tmpdir)
            assert isinstance(chemin, str), (
                f"save_model() doit retourner un str, retourné : {type(chemin).__name__}"
            )
            assert chemin.endswith(".pkl"), (
                f"Le chemin retourné doit terminer par '.pkl' : {chemin}"
            )

    def test_fichier_rechargeable_avec_joblib(self, modele_entraine):
        """
        Le fichier sauvegardé doit pouvoir être rechargé avec joblib.load()
        et l'objet doit exposer predict().
        """
        import joblib

        with tempfile.TemporaryDirectory() as tmpdir:
            chemin = save_model(modele_entraine, "XGBoost", output_dir=tmpdir)
            modele_recharge = joblib.load(chemin)

            assert hasattr(modele_recharge, "predict"), (
                "Le modèle rechargé n'a pas de méthode predict()"
            )

    def test_modele_recharge_predit_correctement(self, modele_entraine,
                                                   jeu_classification):
        """
        Le modèle rechargé depuis le .pkl doit produire les mêmes prédictions
        que le modèle original (intégrité de la sérialisation).
        """
        import joblib

        X_test = jeu_classification["X_test"]
        preds_avant = modele_entraine.predict(X_test)

        with tempfile.TemporaryDirectory() as tmpdir:
            chemin = save_model(modele_entraine, "XGBoost", output_dir=tmpdir)
            modele_recharge = joblib.load(chemin)
            preds_apres = modele_recharge.predict(X_test)

        np.testing.assert_array_equal(
            preds_avant, preds_apres,
            err_msg="Les prédictions avant/après sauvegarde-rechargement diffèrent."
        )

    def test_ecrasement_fichier_existant(self, modele_entraine):
        """
        Si un fichier .pkl existe déjà au même chemin, save_model()
        doit l'écraser sans erreur.
        """
        import joblib

        with tempfile.TemporaryDirectory() as tmpdir:
            # Premier save
            chemin = save_model(modele_entraine, "XGBoost", output_dir=tmpdir)
            mtime1 = os.path.getmtime(chemin)

            import time; time.sleep(0.05)  # garantit un mtime différent

            # Deuxième save — ne doit pas lever d'exception
            chemin2 = save_model(modele_entraine, "XGBoost", output_dir=tmpdir)
            mtime2  = os.path.getmtime(chemin2)

            assert chemin == chemin2, "Le chemin retourné a changé entre les deux saves."
            assert mtime2 >= mtime1,  "Le fichier n'a pas été mis à jour."

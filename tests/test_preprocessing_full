class TestHandleOutliers:
    """
    Vérifie que handle_outliers() :
      - écrête les valeurs extrêmes via la règle IQR 1.5
      - ne touche pas la colonne cible 'survival_status'
      - conserve le shape du DataFrame
      - ne produit pas de NaN dans les colonnes numériques
    """

    def test_outliers_hauts_ecretes(self, df_numerique):
        """
        Toutes les valeurs numériques (hors cible) doivent être
        inférieures ou égales à Q3 + 1.5 * IQR après écrêtage.
        """
        from data_processing import handle_outliers
        df_out = handle_outliers(df_numerique.copy())

        for col in ["Donorage", "CD34kgx10d6", "Recipientage", "Rbodymass"]:
            Q1 = df_numerique[col].quantile(0.25)
            Q3 = df_numerique[col].quantile(0.75)
            upper = Q3 + 1.5 * (Q3 - Q1)
            assert df_out[col].max() <= upper + 1e-6, (
                f"Colonne '{col}' : max après écrêtage = {df_out[col].max():.4f}, "
                f"borne haute = {upper:.4f}"
            )

    def test_outliers_bas_ecretes(self, df_numerique):
        """
        Toutes les valeurs numériques (hors cible) doivent être
        supérieures ou égales à Q1 - 1.5 * IQR après écrêtage.
        """
        from data_processing import handle_outliers
        df_out = handle_outliers(df_numerique.copy())

        for col in ["Donorage", "CD34kgx10d6", "Recipientage", "Rbodymass"]:
            Q1 = df_numerique[col].quantile(0.25)
            Q3 = df_numerique[col].quantile(0.75)
            lower = Q1 - 1.5 * (Q3 - Q1)
            assert df_out[col].min() >= lower - 1e-6, (
                f"Colonne '{col}' : min après écrêtage = {df_out[col].min():.4f}, "
                f"borne basse = {lower:.4f}"
            )

    def test_colonne_cible_non_modifiee(self, df_numerique):
        """
        'survival_status' ne doit pas être écrêtée — ses valeurs
        doivent rester identiques à l'original.
        """
        from data_processing import handle_outliers
        cible_avant = df_numerique["survival_status"].copy()
        df_out = handle_outliers(df_numerique.copy())

        pd.testing.assert_series_equal(
            df_out["survival_status"].reset_index(drop=True),
            cible_avant.reset_index(drop=True),
            check_names=False, check_dtype=False
        )

    def test_shape_inchange(self, df_numerique):
        """
        handle_outliers() ne doit pas supprimer de lignes ou de colonnes.
        """
        from data_processing import handle_outliers
        df_out = handle_outliers(df_numerique.copy())
        assert df_out.shape == df_numerique.shape

    def test_pas_de_nan_apres_ecrêtage(self, df_numerique):
        """
        L'écrêtage ne doit pas introduire de NaN dans le DataFrame.
        """
        from data_processing import handle_outliers
        df_out = handle_outliers(df_numerique.copy())
        assert df_out.isnull().sum().sum() == 0, (
            "handle_outliers() a introduit des NaN dans le DataFrame."
        )



class TestEncodeFeatures:
    """
    Vérifie que encode_features() :
      - convertit toutes les colonnes object en int
      - ne produit pas de NaN
      - conserve les colonnes numériques existantes
      - conserve la forme du DataFrame
    """

    def test_plus_aucune_colonne_object(self, df_categoriel):
        """
        Après encodage, il ne doit plus rester de colonnes de type object.
        """
        df_enc = encode_features(df_categoriel.copy())
        cols_object = df_enc.select_dtypes(include=["object"]).columns.tolist()
        assert cols_object == [], (
            f"Colonnes object restantes après encode_features() : {cols_object}"
        )

    def test_colonnes_encodees_sont_numeriques(self, df_categoriel):
        """
        Les colonnes précédemment object doivent être de type int après encodage.
        """
        cols_object_avant = df_categoriel.select_dtypes(include=["object"]).columns.tolist()
        df_enc = encode_features(df_categoriel.copy())

        for col in cols_object_avant:
            assert pd.api.types.is_numeric_dtype(df_enc[col]), (
                f"Colonne '{col}' toujours non-numérique après encode_features()"
            )

    def test_pas_de_nan_introduits(self, df_categoriel):
        """
        encode_features() ne doit pas générer de NaN.
        """
        df_enc = encode_features(df_categoriel.copy())
        assert df_enc.isnull().sum().sum() == 0

    def test_colonnes_numeriques_inchangees(self, df_categoriel):
        """
        Les colonnes déjà numériques (Donorage, survival_status) ne doivent
        pas être modifiées par l'encodage.
        """
        df_enc = encode_features(df_categoriel.copy())
        np.testing.assert_array_almost_equal(
            df_categoriel["Donorage"].values,
            df_enc["Donorage"].values,
            decimal=5,
            err_msg="La colonne 'Donorage' a été modifiée par encode_features()"
        )

    def test_shape_inchange(self, df_categoriel):
        """
        encode_features() ne doit ni ajouter ni supprimer de colonnes.
        """
        df_enc = encode_features(df_categoriel.copy())
        assert df_enc.shape == df_categoriel.shape

    def test_valeurs_encodees_commencent_a_zero(self, df_categoriel):
        """
        LabelEncoder encode à partir de 0 — la valeur minimale de chaque
        colonne encodée doit être >= 0.
        """
        cols_object = df_categoriel.select_dtypes(include=["object"]).columns.tolist()
        df_enc = encode_features(df_categoriel.copy())

        for col in cols_object:
            assert df_enc[col].min() >= 0, (
                f"Colonne '{col}' : valeur min = {df_enc[col].min()} (attendu >= 0)"
            )



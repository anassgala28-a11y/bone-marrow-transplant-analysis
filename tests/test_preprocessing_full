# 4. SUPPRESSION DES FEATURES CORRÉLÉES  ─  drop_correlated_features()
# ══════════════════════════════════════════════════════════════════════════════

class TestDropCorrelatedFeatures:
    """
    Vérifie que drop_correlated_features() :
      - supprime les colonnes fortement corrélées (> seuil)
      - conserve la colonne cible 'survival_status'
      - conserve les colonnes indépendantes
      - ne supprime rien si le seuil est très élevé (1.0)
    """

    def test_colonne_correlee_supprimee(self, df_correlations):
        """
        Avec le seuil par défaut 0.95, l'une des deux colonnes
        fortement corrélées doit être supprimée.
        """
        df_red = drop_correlated_features(df_correlations.copy(), threshold=0.95)
        cols = set(df_red.columns)
        # L'une ou l'autre doit être supprimée, pas les deux
        assert not (("feature_a" in cols) and ("feature_b" in cols)), (
            "Les deux colonnes fortement corrélées sont encore présentes "
            "alors que l'une devrait avoir été supprimée."
        )

    def test_colonne_independante_conservee(self, df_correlations):
        """
        'feature_c', indépendante des autres, ne doit pas être supprimée.
        """
        df_red = drop_correlated_features(df_correlations.copy(), threshold=0.95)
        assert "feature_c" in df_red.columns, (
            "'feature_c' a été supprimée alors qu'elle est indépendante."
        )

    def test_cible_toujours_presente(self, df_correlations):
        """
        'survival_status' ne doit jamais être supprimée, même si elle
        corrèle avec une feature.
        """
        df_red = drop_correlated_features(df_correlations.copy(), threshold=0.95)
        assert "survival_status" in df_red.columns, (
            "'survival_status' a été supprimée par drop_correlated_features()"
        )

    def test_seuil_1_rien_supprime(self, df_correlations):
        """
        Avec un seuil de 1.0, aucune colonne ne devrait être supprimée
        (corrélation parfaite = 1.0 est impossible entre colonnes distinctes).
        """
        n_cols_avant = df_correlations.shape[1]
        df_red = drop_correlated_features(df_correlations.copy(), threshold=1.0)
        assert df_red.shape[1] == n_cols_avant, (
            f"Seuil=1.0 : {n_cols_avant - df_red.shape[1]} colonne(s) supprimée(s) à tort."
        )

    def test_moins_ou_egal_colonnes_original(self, df_correlations):
        """
        Le résultat ne peut avoir plus de colonnes qu'à l'entrée.
        """
        df_red = drop_correlated_features(df_correlations.copy(), threshold=0.95)
        assert df_red.shape[1] <= df_correlations.shape[1]



# 5. SPLIT & BALANCE  ─  split_and_balance()
# ══════════════════════════════════════════════════════════════════════════════

class TestSplitAndBalance:
    """
    Vérifie que split_and_balance() :
      - retourne 4 objets (X_train, X_test, y_train, y_test)
      - SMOTE est appliqué uniquement sur l'ensemble d'entraînement
      - les classes de y_train sont équilibrées après SMOTE
      - y_test n'est PAS modifié par SMOTE (déséquilibre original conservé)
      - les colonnes de X_train correspondent aux features (pas la cible)
      - les features de leakage post-transplant sont absentes de X_train
    """

    def test_retourne_quatre_elements(self, df_balance):
        """
        split_and_balance() doit retourner exactement 4 éléments.
        """
        result = split_and_balance(df_balance.copy())
        assert len(result) == 4, (
            f"Attendu 4 éléments (X_train, X_test, y_train, y_test), "
            f"obtenu {len(result)}"
        )

    def test_cible_absente_de_x_train(self, df_balance):
        """
        'survival_status' ne doit pas apparaître comme feature dans X_train.
        """
        X_train, X_test, y_train, y_test = split_and_balance(df_balance.copy())
        assert "survival_status" not in X_train.columns, (
            "La colonne cible 'survival_status' est présente dans X_train !"
        )

    def test_cible_absente_de_x_test(self, df_balance):
        """
        'survival_status' ne doit pas apparaître comme feature dans X_test.
        """
        X_train, X_test, y_train, y_test = split_and_balance(df_balance.copy())
        assert "survival_status" not in X_test.columns

    def test_smote_equilibre_y_train(self, df_balance):
        """
        Après SMOTE, y_train doit contenir autant d'exemples de chaque classe
        (ratio 1:1 attendu avec les paramètres par défaut de SMOTE).
        """
        X_train, _, y_train, _ = split_and_balance(df_balance.copy())
        counts = pd.Series(y_train).value_counts()
        assert counts[0] == counts[1], (
            f"Classes déséquilibrées dans y_train après SMOTE : "
            f"classe 0 = {counts.get(0,0)}, classe 1 = {counts.get(1,0)}"
        )

    def test_y_test_non_modifie_par_smote(self, df_balance):
        """
        SMOTE ne doit pas toucher y_test : le déséquilibre original doit
        être conservé dans l'ensemble de test.
        """
        _, X_test, _, y_test = split_and_balance(df_balance.copy())
        # y_test doit avoir les deux classes sans équilibrage artificiel
        counts = pd.Series(y_test).value_counts()
        assert len(counts) == 2, (
            "y_test ne contient pas les deux classes — problème de split."
        )
        # Les proportions ne doivent PAS être 50/50
        ratio = min(counts) / max(counts)
        assert ratio < 0.99, (
            f"y_test semble équilibré (ratio={ratio:.2f}) — SMOTE a peut-être "
            "été appliqué sur le test set !"
        )

    def test_taille_test_set_20_pourcent(self, df_balance):
        """
        Avec test_size=0.2 (défaut), X_test doit représenter ~20% des données.
        """
        X_train, X_test, y_train, y_test = split_and_balance(df_balance.copy())
        n_total_original = len(df_balance)
        n_test = len(X_test)
        ratio = n_test / n_total_original
        assert 0.15 <= ratio <= 0.25, (
            f"Taille du test set : {n_test}/{n_total_original} = {ratio:.1%} "
            f"(attendu ~20%)"
        )

    def test_features_leakage_absentes_de_x_train(self, df_balance):
        """
        Les features de leakage post-transplant ne doivent jamais apparaître
        dans X_train — test de régression contre le bug de leakage corrigé.
        """
        X_train, _, _, _ = split_and_balance(df_balance.copy())
        leakage_cols = [
            "ANCrecovery", "PLTrecovery",
            "time_to_aGvHD_III_IV", "survival_time"
        ]
        cols_leakage_presentes = [c for c in leakage_cols if c in X_train.columns]
        assert cols_leakage_presentes == [], (
            f"Features de leakage détectées dans X_train : {cols_leakage_presentes}"
        )

    def test_memes_colonnes_x_train_x_test(self, df_balance):
        """
        X_train et X_test doivent avoir exactement les mêmes colonnes.
        """
        X_train, X_test, _, _ = split_and_balance(df_balance.copy())
        assert list(X_train.columns) == list(X_test.columns), (
            f"Colonnes différentes entre X_train et X_test.\n"
            f"X_train : {list(X_train.columns)}\n"
            f"X_test  : {list(X_test.columns)}"
        )



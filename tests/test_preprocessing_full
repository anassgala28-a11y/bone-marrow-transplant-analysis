class TestLoadData:
    """
    Vérifie que load_data() :
      - retourne un pd.DataFrame
      - décode correctement les bytes en str (colonnes object)
      - conserve toutes les lignes et colonnes du fichier source
    """

    def _make_mock_arff(self):
        """
        Crée un faux résultat de arff.loadarff() :
        - data : liste de tuples numpy avec bytes
        - meta : objet simulé (non utilisé dans load_data)
        """
        # Simuler des données brutes retournées par scipy.io.arff
        data = np.array(
            [(b"ALL", 1.0, 25.0, 0),
             (b"AML", 0.0, 35.0, 1),
             (b"chronic", 1.0, 42.0, 0)],
            dtype=[("Disease", "S10"), ("Stemcellsource", "<f8"),
                   ("Donorage", "<f8"), ("survival_status", "<i8")]
        )
        meta = MagicMock()
        return data, meta

    def test_retourne_un_dataframe(self):
        """
        load_data() doit retourner un pd.DataFrame, pas un tableau numpy.
        """
        data, meta = self._make_mock_arff()

        with patch("data_processing.arff.loadarff", return_value=(data, meta)):
            df = load_data("fake_path.arff")

        assert isinstance(df, pd.DataFrame), (
            f"Type retourné : {type(df)}, attendu : pd.DataFrame"
        )

    def test_bytes_decodes_en_str(self):
        """
        Les colonnes contenant des bytes (type object après chargement ARFF)
        doivent être converties en str lisibles.
        """
        data, meta = self._make_mock_arff()

        with patch("data_processing.arff.loadarff", return_value=(data, meta)):
            df = load_data("fake_path.arff")

        # Vérifier que la colonne 'Disease' ne contient plus de bytes
        for val in df["Disease"]:
            assert isinstance(val, str), (
                f"Valeur non décodée : {val!r} (type : {type(val).__name__})"
            )
        assert "ALL" in df["Disease"].values

    def test_nombre_lignes_colonnes_correct(self):
        """
        Le DataFrame doit avoir le même nombre de lignes que le tableau ARFF
        et une colonne par champ.
        """
        data, meta = self._make_mock_arff()

        with patch("data_processing.arff.loadarff", return_value=(data, meta)):
            df = load_data("fake_path.arff")

        assert df.shape[0] == 3,  f"Attendu 3 lignes, obtenu {df.shape[0]}"
        assert df.shape[1] == 4,  f"Attendu 4 colonnes, obtenu {df.shape[1]}"

    def test_colonnes_numeriques_preservees(self):
        """
        Les colonnes numériques du fichier ARFF doivent rester numériques
        après chargement (pas de conversion en str).
        """
        data, meta = self._make_mock_arff()

        with patch("data_processing.arff.loadarff", return_value=(data, meta)):
            df = load_data("fake_path.arff")

        assert pd.api.types.is_numeric_dtype(df["Donorage"]), (
            "La colonne 'Donorage' doit rester numérique après load_data()"
        )


